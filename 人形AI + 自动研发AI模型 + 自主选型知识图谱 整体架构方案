from fastapi import FastAPI, WebSocket, WebSocketDisconnect
import uvicorn
from loguru import logger
import config
from humanoid_terminal import humanoid
from kg_engine import kg_engine
from auto_model_train import model_engine

app = FastAPI(title="人形AI自治系统")

@app.websocket("/ws/humanoid")
async def websocket_humanoid(websocket: WebSocket):
    await websocket.accept()
    logger.info("人形终端WebSocket连接建立")
    try:
        while True:
            # 1. 接收用户输入（模拟人形感知）
            raw_msg = await websocket.receive_text()
            # 2. 解析任务
            task = humanoid.parse_input(raw_msg)
            # 3. 自动选择图谱 + 检索知识
            kg_result = kg_engine.kg_query(raw_msg)
            # 4. 模型推理（融合知识）
            answer = model_engine.infer(raw_msg, kg_result)
            # 5. 人形终端输出结果
            await humanoid.ws_output(websocket, answer)
            # 6. 简易数据回流（触发自动训练）
            model_engine.auto_lora_train(config.DATA_BACKFLOW_PATH)
    except WebSocketDisconnect:
        logger.warning("WebSocket连接断开")

if __name__ == "__main__":
    uvicorn.run(
        "main:app",
        host=config.HOST,
        port=config.PORT,
        reload=True
    )

