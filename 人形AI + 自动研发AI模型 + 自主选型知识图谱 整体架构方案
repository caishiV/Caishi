2. 知识图谱引擎  kg_engine.py 
 
实现图谱自主选型、知识检索、图谱简易更新三大核心能力
python
from py2neo import Graph, Node, Relationship
from loguru import logger
import config

class KGAutoEngine:
    def __init__(self):
        self.graph = Graph(
            config.NEO4J_URI,
            auth=(config.NEO4J_USER, config.NEO4J_PASSWORD)
        )
        logger.info("知识图谱引擎初始化完成")

    def auto_select_kg(self, query_text: str) -> str:
        """AI自主选择图谱：简单语义分类，可后续升级大模型分类"""
        tech_keywords = {"代码", "Python", "模型", "算法", "开发", "训练"}
        text_set = set(query_text)
        if tech_keywords & text_set:
            return config.KG_TAG_TECH
        return config.KG_TAG_GENERAL

    def kg_query(self, query_text: str) -> list:
        """根据选中图谱检索知识三元组"""
        kg_type = self.auto_select_kg(query_text)
        cypher = f"""
        MATCH (n:{kg_type})-[r]->(m)
        WHERE n.name CONTAINS $kw
        RETURN n.name, type(r), m.name LIMIT 5
        """
        res = self.graph.run(cypher, kw=query_text).data()
        return res

    def auto_update_kg(self, entity_a: str, rel: str, entity_b: str, kg_type: str):
        """自动新增知识，完成图谱自演化"""
        a = Node(kg_type, name=entity_a)
        b = Node(kg_type, name=entity_b)
        r = Relationship(a, rel, b)
        self.graph.merge(a)
        self.graph.merge(b)
        self.graph.merge(r)
        logger.success(f"图谱自动更新: {entity_a} -{rel}-> {entity_b}")

# 单例实例
kg_engine = KGAutoEngine()

